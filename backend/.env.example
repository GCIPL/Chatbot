# Copy to .env and set values. Do not commit .env.

# LLM — set which provider to use when both keys exist
LLM_PROVIDER=openai
# OpenAI (set key and LLM_PROVIDER=openai to use)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# Gemini (set key and LLM_PROVIDER=gemini to use)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# OPENAI_API_BASE=https://your-azure-openai-endpoint.openai.azure.com/
# OPENAI_API_VERSION=2024-02-15
# OPENAI_DEPLOYMENT=gpt-4

# Emp portal (internal API)
EMP_PORTAL_BASE_URL=https://emp-portal.ghorahicement.com
SALES_FORCE_ABC=105
# ChatBothLink dashboard — Name + Web_Excel_Address for assistant UI shortcuts
SALES_FORCE_ABC_CHATBOT_LINKS=109

# Optional: pass session cookie from frontend; backend forwards to emp-portal
# ASSISTANT_SESSION_COOKIE_HEADER=Cookie

# App
ASSISTANT_ENV=development
LOG_LEVEL=INFO
